<idea-plugin>
    <id>com.github.yamert89.drift-locator</id>
    <name>Drift Locator</name>
    <version>0.1.0</version>
    <vendor email="yamert89@github.com" url="https://github.com/yamert89">yamert89</vendor>

    <description><![CDATA[
        Plugin for comparing database schemas across different DBMS.
    ]]></description>

    <change-notes><![CDATA[
        Initial version.
    ]]></change-notes>

    <idea-version since-build="241"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="DriftLocator" anchor="bottom" factoryClass="com.github.yamert89.plugin.DriftLocatorToolWindowFactory"/>
    </extensions>

    <actions>
        <group id="com.github.yamert89.plugin.toolWindow" text="Drift Locator" description="Drift locator actions">
            <add-to-group group-id="MainMenu" anchor="last"/>
            <action id="com.github.yamert89.plugin.AddConnectionAction"
                    class="com.github.yamert89.plugin.AddConnectionAction" text="Add Connection"
                    icon="AllIcons.Actions.AddFile"
                    description="Add connection"/>
            <action id="DriftLocatorAction" class="com.github.yamert89.plugin.DriftLocatorAction" text="Compare Schemas"
                    icon="AllIcons.Actions.Compile"
                    description="Compare database schemas"/>
            <action id="com.github.yamert89.plugin.DeleteConnectionAction"
                    class="com.github.yamert89.plugin.DeleteConnectionAction" text="Delete"
                    icon="AllIcons.Actions.DeleteTag"
                    description="Delete connection"/>
        </group>

    </actions>
</idea-plugin>
